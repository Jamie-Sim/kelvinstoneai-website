# CTA form backend (POST /api/submit).
# Set the same values in Vercel: Project Settings → Environment Variables.

# Supabase — leads database.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Resend — lead notification emails.
RESEND_API_KEY=
LEAD_NOTIFY_TO=jamie@kelvinstone.ai
LEAD_NOTIFY_FROM=Kelvinstone Leads <leads@kelvinstone.ai>

# Airtable — leads CRM (user-facing view of submissions).
# AIRTABLE_TOKEN: Personal Access Token from airtable.com/create/tokens with
# scope `data.records:write` on the leads base.
# AIRTABLE_BASE_ID: 'appXXXXXXXXXXXXXX' from the base URL.
# AIRTABLE_TABLE_ID: 'tblXXXXXXXXXXXXXX' from the table URL — using the ID (not
# the display name) means renaming the table later won't break the integration.
AIRTABLE_TOKEN=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_ID=
